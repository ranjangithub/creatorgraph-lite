# ── Mock mode ─────────────────────────────────────────────────────────────
# Copy this file to .env.local to run with zero real API keys.
# Requires Docker for local Postgres (see README — Local dev with mocks).
#
# Usage:
#   docker compose up -d
#   cp .env.local.mock .env.local
#   npm run db:push
#   npm run db:seed-mock
#   npm run dev

MOCK_AUTH=true

# ── Local Postgres (via docker compose) ───────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creatorgraph

# ── Anthropic mock ─────────────────────────────────────────────────────────
# Set to sk-mock to use fixture responses — no real API calls made.
ANTHROPIC_API_KEY=sk-mock

# ── Clerk placeholders (unused in mock mode) ──────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_mock_placeholder
CLERK_SECRET_KEY=sk_test_mock_placeholder
CLERK_WEBHOOK_SECRET=whsec_mock_placeholder

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/briefing
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/import

# ── Supabase placeholders (unused in mock mode — using local Postgres) ────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=mock_anon_key
SUPABASE_SERVICE_ROLE_KEY=mock_service_role_key
